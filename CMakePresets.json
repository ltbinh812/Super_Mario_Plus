{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows (MSVC)",
      "description": "Configure using Microsoft Visual Studio compiler",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "windows-mingw",
      "displayName": "Windows (MinGW)",
      "description": "Configure using MinGW/GCC compiler",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc",
      "configurePreset": "windows-msvc",
      "configuration": "Debug"
    },
    {
      "name": "windows-mingw",
      "configurePreset": "windows-mingw"
    }
  ]
}